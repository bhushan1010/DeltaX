# ─────────────────────────────────────────────────────────────────────────────
# DeltaX — Environment Variable Reference
# Copy this file to .env for local development.
# On Railway, set these in the Railway dashboard (Variables tab).
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres plugin.
# It combines all the individual fields below into a single connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# ── JWT Secrets (use long, random strings — at least 32 chars) ────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# If serving the React app from the same Express server, leave this as your
# Railway public domain (e.g. https://deltax.up.railway.app).
# You can list multiple: CORS_ORIGIN=https://deltax.up.railway.app,http://localhost:3000
CORS_ORIGIN=https://YOUR_RAILWAY_DOMAIN.up.railway.app
